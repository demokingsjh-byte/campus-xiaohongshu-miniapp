# 生产环境：只在打包时使用
NODE_ENV=production

VITE_DEV=false

# 请求路径：生产环境走当前站点的 nginx 反向代理
VITE_BASE_URL=''

# 文件上传类型：server - 后端上传， client - 前端直连上传，仅支持S3服务
VITE_UPLOAD_TYPE=server

# 接口地址
VITE_API_URL=/admin-api

# 是否删除debugger
VITE_DROP_DEBUGGER=true

# 是否删除console.log
VITE_DROP_CONSOLE=true

# 是否sourcemap
VITE_SOURCEMAP=false

# 是否开启压缩，可以设置为 none, gzip, brotli, gzip,brotli
VITE_COMPRESS=none

# 打包路径
VITE_BASE_PATH=/

# 输出路径
VITE_OUT_DIR=dist

# 商城H5会员端域名
VITE_MALL_H5_DOMAIN='http://121.43.83.21:8088'

# GoView域名
VITE_GOVIEW_URL='http://127.0.0.1:3000'
